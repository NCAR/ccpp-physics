  units = count
  dimensions = ()
  type = integer
  intent = in
[nlev]
  standard_name = vertical_layer_dimension
  long_name = number of vertical levels
  units = count
  dimensions = ()
  type = integer
  intent = in
[con_g]
  standard_name = gravitational_acceleration
  long_name = gravitational acceleration
